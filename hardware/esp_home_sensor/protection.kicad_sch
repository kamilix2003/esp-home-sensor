	(text "V_{RS} = V_{CS} - V_{SS}\n\nV_{RS} = I_R / R_S\n\nI_{CHG} = 440mA => \nR_S > I_R / OCC\nR_S > 12.2 Ohm\n\nI_{DCHG} = 720mA @ R_S = 12 Ohm\n\nI_{CHG} = 540mA @ R_S = 15 Ohm\nI_{DCHG} = 900mA @ R_S = 15 Ohm\n\nP_{R_S} = I^2 / R = .05W"
